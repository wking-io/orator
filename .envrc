# Load local binaries first
export PATH="$PWD/node_modules/.bin:$PATH"

# Pin Bun version for reproducible dev
export BUN_VERSION="1.3.5"

# Note: This auto-install block requires network access.
if ! command -v bun &> /dev/null || [[ "$(bun --version)" != "$BUN_VERSION" ]]; then
  echo "Bun $BUN_VERSION not found; install it (see https://bun.sh)"
fi
